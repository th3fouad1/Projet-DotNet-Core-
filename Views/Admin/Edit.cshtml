@model ASVS_Security_Auditor.Core.Entities.AsvsRequirement
@{
    ViewData["Title"] = "Modifier l'Exigence";
}

<div class="container mt-4 max-w-75">
    <h2>Modifier l'exigence ASVS</h2>
    <hr />
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="SectionId" />
                        <input type="hidden" asp-for="SectionName" />
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="ChapterId" class="form-label">ID Chapitre</label>
                                <input asp-for="ChapterId" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ChapterName" class="form-label">Nom Chapitre</label>
                                <input asp-for="ChapterName" class="form-control" required />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Item" class="form-label">Item ID</label>
                                <input asp-for="Item" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Cwe" class="form-label">CWE</label>
                                <input asp-for="Cwe" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description complète</label>
                            <textarea asp-for="Description" class="form-control" rows="4" required></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label d-block">Niveaux requis</label>
                            <div class="form-check form-check-inline">
                                <input asp-for="L1" class="form-check-input" type="checkbox" />
                                <label asp-for="L1" class="form-check-label">Level 1</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input asp-for="L2" class="form-check-input" type="checkbox" />
                                <label asp-for="L2" class="form-check-label">Level 2</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input asp-for="L3" class="form-check-input" type="checkbox" />
                                <label asp-for="L3" class="form-check-label">Level 3</label>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">Retour à la liste</a>
                            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Mettre à jour</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
