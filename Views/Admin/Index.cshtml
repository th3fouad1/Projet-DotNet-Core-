@model ASVS_Security_Auditor.Models.AdminIndexViewModel
@{
    ViewData["Title"] = "Administration CRUD";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Panneau d'Administration</h1>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Nouvelle Exigence</a>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4 shadow-sm">
    <div class="card-header bg-light cursor-pointer" data-bs-toggle="collapse" data-bs-target="#importCollapse" style="cursor: pointer;">
        <h5 class="mb-0 mb-0">Importer depuis un fichier Excel (OWASP ASVS) <i class="bi bi-chevron-down float-end"></i></h5>
    </div>
    <div id="importCollapse" class="collapse">
        <div class="card-body">
            <div class="alert alert-warning">
                <strong>Attention :</strong> L'importation d'un nouveau fichier écrasera toutes les exigences actuelles de la base de données.
            </div>
            <form asp-action="Import" enctype="multipart/form-data" method="post" class="d-flex align-items-end">
                <div class="flex-grow-1 me-3">
                    <label asp-for="ImportModel.ExcelFile" class="form-label">Fichier Excel ASVS (.xlsx)</label>
                    <input asp-for="ImportModel.ExcelFile" class="form-control" type="file" accept=".xlsx" required />
                </div>
                <button type="submit" class="btn btn-primary">Importer les données</button>
            </form>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white">
        <h5 class="mb-0">Gestion des Exigences (CRUD)</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive" style="max-height: 600px;">
            <table class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-dark" style="position: sticky; top: 0;">
                    <tr>
                        <th>Chapitre</th>
                        <th>Item</th>
                        <th>Description</th>
                        <th>Niv</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if(!Model.Requirements.Any())
                    {
                        <tr><td colspan="5" class="text-center p-4">Aucune donnée trouvée. Créez-en une ou importez un fichier Excel.</td></tr>
                    }
                    @foreach (var req in Model.Requirements)
                    {
                        <tr>
                            <td>@req.ChapterId</td>
                            <td class="fw-bold">@req.Item</td>
                            <td title="@req.Description">
                                @(req.Description.Length > 80 ? req.Description.Substring(0, 80) + "..." : req.Description)
                            </td>
                            <td>
                                @if (req.L1) { <span class="badge bg-success">L1</span> }
                                @if (req.L2) { <span class="badge bg-success">L2</span> }
                                @if (req.L3) { <span class="badge bg-success">L3</span> }
                            </td>
                            <td class="text-end text-nowrap">
                                <a asp-action="Edit" asp-route-id="@req.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                
                                <form asp-action="Delete" asp-route-id="@req.Id" method="post" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette exigence ?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
