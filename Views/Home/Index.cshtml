@model IEnumerable<ASVS_Security_Auditor.Core.Entities.AsvsRequirement>
@{
    ViewData["Title"] = "Checklist Publique ASVS";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Checklist OWASP ASVS 4.0</h1>
        <p class="lead">Standard de Vérification de la Sécurité des Applications</p>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            Aucune exigence ASVS n'a été trouvée dans la base de données. Veuillez contacter un administrateur pour les importer.
        </div>
    }
    else
    {
        <div class="accordion" id="asvsAccordion">
            @foreach (var chapter in Model.GroupBy(r => new { r.ChapterId, r.ChapterName }))
            {
                <div class="accordion-item mb-3 shadow-sm">
                    <h2 class="accordion-header" id="heading-@chapter.Key.ChapterId.Replace(".", "-")">
                        <button class="accordion-button collapsed fw-semibold fs-5" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@chapter.Key.ChapterId.Replace(".", "-")">
                            Chapitre @chapter.Key.ChapterId: @chapter.Key.ChapterName
                        </button>
                    </h2>
                    <div id="collapse-@chapter.Key.ChapterId.Replace(".", "-")" class="accordion-collapse collapse" data-bs-parent="#asvsAccordion">
                        <div class="accordion-body p-0">
                            <div class="table-responsive">
                                <table class="table table-striped table-hover m-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 10%">Point</th>
                                            <th style="width: 60%">Description</th>
                                            <th style="width: 10%">Niv 1</th>
                                            <th style="width: 10%">Niv 2</th>
                                            <th style="width: 10%">Niv 3</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var req in chapter)
                                        {
                                            <tr>
                                                <td class="fw-bold text-nowrap">@req.Item</td>
                                                <td>@req.Description</td>
                                                <td class="text-center">
                                                    @if (req.L1) { <span class="badge bg-success">✓</span> }
                                                </td>
                                                <td class="text-center">
                                                    @if (req.L2) { <span class="badge bg-success">✓</span> }
                                                </td>
                                                <td class="text-center">
                                                    @if (req.L3) { <span class="badge bg-success">✓</span> }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
