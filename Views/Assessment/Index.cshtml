@model IEnumerable<ASVS_Security_Auditor.Core.Entities.Assessment>

@{
    ViewData["Title"] = "Évaluations";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Évaluations</h1>
        
        <form asp-action="Create" method="post" class="d-flex">
            <input type="text" name="name" class="form-control me-2" placeholder="Nom du projet" required />
            <button type="submit" class="btn btn-primary">Nouvelle évaluation</button>
        </form>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">
        @foreach (var assessment in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">@assessment.Name</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@assessment.DateCreated.ToShortDateString()</h6>
                        <p class="card-text">
                            Total des points: @assessment.Items.Count <br/>
                            En attente: @assessment.Items.Count(i => i.Status == ASVS_Security_Auditor.Core.Entities.AssessmentStatus.Pending)
                        </p>
                        <a asp-action="Details" asp-route-id="@assessment.Id" class="btn btn-outline-primary w-100">Continuer l'audit</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
