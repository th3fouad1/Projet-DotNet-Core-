## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## See https://learn.microsoft.com/en-us/visualstudio/ide/applying-dot-net-git-ignore?view=vs-2022

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the TestResults folder
#TestResults/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Entity Framework 6 (v6.x)
*.Migrations.cs

# Entity Framework Core (v2.x - v6.x)
# Migrations are generally committed to source control.
# Uncomment if you want to exclude them.
# [Mm]igrations/

# CoreCLR
stacked.out

# AZURE
PublishScripts/
bin/Debug/PublishOutput/
bin/Release/PublishOutput/

# Microsoft Azure Build Output
csx/
*.build.csdef

# Azure Cloud Service Item Logs
ecf/
rcf/

# Windows Azure Emulator caches
ServiceDefinition.build.csdef
ServiceDefinition.rd

# Azure Functions local.settings.json
local.settings.json

# Visual Studio Code
.vscode/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Mac OS
.DS_Store

# User-specific files
*.db
*.db-shm
*.db-wal
appsettings.Development.json
